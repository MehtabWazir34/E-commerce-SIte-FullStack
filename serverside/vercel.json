{
    "version": 2,
    "installCommand": "npm install --legacy-peer-deps",
    "builds":[
        {
        "src": "api/index.js",
        "use": "@vercel/node"
    },
    {
        "src":"src/**/*",
        "use":"@vercel/static"
    }
    ],
    "routes":[
        {"src":"/api/(.*)", "dest":"/api/index.js"},
        {"src":"/(.*)", "dest":"/"}
    ]

}